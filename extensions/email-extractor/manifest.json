{
  "name": "Email Extractor → CSV",
  "description": "Extract unique email addresses from the current page and export them to CSV.",
  "version": "1.0.0",
  "manifest_version": 3,

  "action": {
    "default_title": "Email Extractor",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["<all_urls>"],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
