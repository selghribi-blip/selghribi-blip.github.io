{
  "name": "email-extractor-extension",
  "private": true,
  "version": "1.1.0",
  "description": "Build pipeline for Email Extractor Chrome Extension (Tailwind CSS).",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/input.css -o ./tailwind.css --minify",
    "watch:css": "tailwindcss -c tailwind.config.js -i ./src/input.css -o ./tailwind.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13"
  }
}
