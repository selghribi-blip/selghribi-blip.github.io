{
  "name": "email-extractor-extension",
  "version": "1.0.0",
  "description": "Chrome Extension (MV3) – Email Extractor with real Tailwind CSS build pipeline",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./tailwind.css --minify",
    "build": "npm run build:css",
    "watch:css": "tailwindcss -i ./src/input.css -o ./tailwind.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.0.7",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.19"
  }
}
