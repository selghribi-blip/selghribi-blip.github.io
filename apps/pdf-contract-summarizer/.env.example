APP_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (development / single-server). Replace with PostgreSQL for production.
DATABASE_URL="file:./dev.db"

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
AUTH_SECRET=replace_with_random_secret

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth App (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pro plan – base monthly recurring price (fixed amount, e.g. $9/month)
# Create in Stripe Dashboard: Products → Add product → Add price
#   Type: Recurring, Billing period: Monthly, Amount: $9.00
STRIPE_PRICE_PRO_BASE=price_...

# Pro plan – metered overage price ($0.05 per extra summary beyond 200/month)
# Create in Stripe Dashboard: Products → same product → Add another price
#   Type: Recurring (usage-based), Billing period: Monthly
#   Pricing model: Per unit, Amount: $0.05
#   Usage type: Metered, Aggregate usage: Sum
STRIPE_PRICE_PRO_OVERAGE_METERED=price_...
