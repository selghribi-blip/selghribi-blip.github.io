# ============================================================
# PDF & Contract Summarizer — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# ── Stripe ──────────────────────────────────────────────────
# Your Stripe secret key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=sk_test_...

# Your Stripe publishable key (pk_test_... or pk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...

# Pro Base: recurring fixed price — $19 / month
# Create in Stripe Dashboard → Products → Pro Plan → Add price
#   Type: Recurring | Interval: Monthly | Amount: $19.00
STRIPE_PRICE_PRO_BASE=price_...

# Pro Overage: recurring metered price — $0.05 / unit (sum aggregation)
# Create in Stripe Dashboard → Products → Pro Plan → Add price
#   Type: Recurring | Usage type: Metered | Billing scheme: Per unit
#   Amount: $0.05 | Aggregation mode: Sum
STRIPE_PRICE_PRO_OVERAGE_METERED=price_...

# ── Database ────────────────────────────────────────────────
DATABASE_URL=file:./dev.db

# ── Auth ────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
