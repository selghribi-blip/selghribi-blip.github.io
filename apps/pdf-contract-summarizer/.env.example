# ─────────────────────────────────────────────
#  PDF & Contract Summarizer — Environment Variables
#  Copy this file to .env.local and fill in values.
# ─────────────────────────────────────────────

# ── Auth ──────────────────────────────────────
AUTH_SECRET=your-nextauth-secret-here
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Database ──────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pro Base: $19/month recurring fixed price
# Dashboard → Products → Pro Plan → Pro Base price → copy price ID
STRIPE_PRICE_PRO_BASE=price_...

# Pro Overage: $0.05/unit recurring metered price (aggregation: sum)
# Dashboard → Products → Pro Plan → Pro Overage price → copy price ID
STRIPE_PRICE_PRO_OVERAGE_METERED=price_...

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
