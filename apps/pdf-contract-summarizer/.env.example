# Application
APP_URL=http://localhost:3000

# Database (Prisma / SQLite for development, use Postgres in production)
DATABASE_URL="file:./dev.db"

# OpenAI
OPENAI_API_KEY=sk-...

# NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_random_secret_here

# GitHub OAuth (create at https://github.com/settings/developers)
AUTH_GITHUB_ID=your_github_oauth_client_id
AUTH_GITHUB_SECRET=your_github_oauth_client_secret

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pro subscription: fixed monthly base price
# Create in Stripe Dashboard → Products → Add product → Recurring, $19/month
STRIPE_PRICE_PRO_BASE=price_...

# Pro subscription: metered overage price ($0.05 per additional summary)
# Create in Stripe Dashboard → Products → Add product → Recurring, Usage-based
# Set "Billing meter" with aggregate_usage=sum, usage_type=metered
# Price: $0.05 per unit
STRIPE_PRICE_PRO_OVERAGE_METERED=price_...

# Stripe Billing Meter event name
# Create a Meter in Stripe Dashboard → Billing → Meters
# with event_name matching this value (e.g. pdf_summary_overage)
STRIPE_BILLING_METER_EVENT_NAME=pdf_summary_overage
