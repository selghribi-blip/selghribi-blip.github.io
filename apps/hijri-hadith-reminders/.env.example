# متغيرات البيئة المطلوبة
# انسخ هذا الملف إلى .env وعدّل القيم

# ── قاعدة البيانات ─────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/hijri-hadith

# ── مصادقة JWT ─────────────────────────────────────────────
# استبدل هذا بقيمة عشوائية طويلة وآمنة في الإنتاج
JWT_SECRET=change_this_to_a_long_random_secret_value
JWT_EXPIRES_IN=7d

# ── الخادم ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
