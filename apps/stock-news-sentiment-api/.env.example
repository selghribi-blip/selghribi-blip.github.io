# ─── Database ──────────────────────────────────────────────────────────────────
# SQLite path (default: ./stock_api.db). Use postgresql+psycopg2://... for Postgres.
DATABASE_URL=sqlite:///./stock_api.db

# ─── Security ──────────────────────────────────────────────────────────────────
# Salt used when hashing API keys with SHA-256. Change before first use!
API_KEY_SALT=changeme-salt-replace-me

# Admin key for /v1/admin/* endpoints
ADMIN_API_KEY=my-secret-admin-key-change-me

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Default rate limit for all keys (can be overridden per key in the DB)
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ─── RSS Sources ───────────────────────────────────────────────────────────────
# Comma-separated list of additional RSS URL templates containing {ticker}.
# Example: https://feeds.finance.yahoo.com/rss/2.0/headline?s={ticker}&region=US&lang=en-US
RSS_TEMPLATES=
