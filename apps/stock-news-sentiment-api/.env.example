# ─── Required ────────────────────────────────────────────────────────────────

# Secret key used to protect all admin endpoints.
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=change-me-before-production

# ─── Optional ────────────────────────────────────────────────────────────────

# SQLite (default) or any SQLAlchemy-compatible URL.
# For SQLite, the path is relative to the project root.
# DATABASE_URL=sqlite:///data/app.db

# Rate-limiting defaults (applies to all keys without per-key overrides).
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW_SECONDS=60

# Comma-separated CORS origins (use * for development only).
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Extra RSS URL templates (comma-separated, use {query} as placeholder).
# RSS_EXTRA_TEMPLATES=https://example.com/rss?q={query}
