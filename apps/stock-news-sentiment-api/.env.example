# ── Authentication ──────────────────────────────────────────────────────────
# Comma-separated list of valid API keys (used by the auth dependency).
# Example: API_KEYS=key_abc123,key_def456
API_KEYS=

# Single key fallback (only used when API_KEYS is not set).
# API_KEY=changeme

# ── Rate limiting ────────────────────────────────────────────────────────────
# Maximum number of requests allowed per window (per API key).
RATE_LIMIT_REQUESTS=60

# Duration of the rate-limit window in seconds.
RATE_LIMIT_WINDOW_SECONDS=60

# ── Caching ──────────────────────────────────────────────────────────────────
# TTL in seconds for the in-memory news/sentiment cache (per ticker+limit).
NEWS_CACHE_TTL_SECONDS=120

# ── Upstream fetching ────────────────────────────────────────────────────────
# HTTP request timeout in seconds.
HTTP_TIMEOUT_SECONDS=10.0

# Number of retry attempts for upstream RSS fetches.
HTTP_MAX_RETRIES=3

# User-Agent header sent to upstream RSS sources.
# USER_AGENT=StockNewsSentimentAPI/1.0 (+https://rapidapi.com)

# ── Sentiment engine ─────────────────────────────────────────────────────────
# Engine to use: "vader" (default, no API key required)
SENTIMENT_ENGINE=vader

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development

# ── Optional: Redis-backed rate limiter ──────────────────────────────────────
# Set RATE_LIMITER=redis to enable (requires custom implementation; see docs).
# RATE_LIMITER=redis
# REDIS_URL=redis://localhost:6379/0
