# ─────────────────────────────────────────────────────────────────────────────
# Stock News & Sentiment API — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Required: Secret key used to authenticate admin endpoints.
# Pass this value in the request header:  X-Admin-Key: <ADMIN_API_KEY>
ADMIN_API_KEY=change-me-to-a-strong-secret

# Database URL (SQLite by default).
# The database file is created in the project directory (./app.db) when you
# run uvicorn from apps/stock-news-sentiment-api/.
# Override to use a different path or database engine:
#   sqlite:////absolute/path/to/my.db
#   postgresql://user:pass@localhost:5432/dbname
DATABASE_URL=sqlite:///./app.db
