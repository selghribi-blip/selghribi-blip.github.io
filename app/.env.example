# Environment Variables for PDF & Contract Summarizer
# Copy this file to .env.local and fill in your values

# App URL (use your deployed subdomain)
NEXTAUTH_URL=https://app.artsmoroccan.me
NEXTAUTH_SECRET=your-nextauth-secret-here  # Generate with: openssl rand -base64 32

# OAuth Providers
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_live_...           # or sk_test_... for testing
STRIPE_PUBLISHABLE_KEY=pk_live_...      # or pk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...         # From Stripe Dashboard > Webhooks

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...   # Pro plan monthly subscription price

# OpenAI (for summarization)
OPENAI_API_KEY=sk-...

# Rate limiting (Free plan)
FREE_PLAN_DAILY_LIMIT=5                 # Max PDF summaries per day for free users
